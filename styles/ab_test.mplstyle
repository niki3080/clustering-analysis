figure.figsize: 8, 4
figure.dpi: 100

font.family: monospace
font.monospace: Courier New, Consolas

font.size: 11
axes.titlesize: 14
axes.titleweight: bold
axes.titlecolor: "#555555"
axes.titlepad: 15
axes.labelsize: 12
axes.labelpad: 10

xtick.labelsize: 10
ytick.labelsize: 10

figure.facecolor: none
axes.facecolor: white

axes.edgecolor: "#7B7B7B"
axes.linewidth: 1
axes.spines.top: False
axes.spines.right: False
axes.spines.left: True
axes.spines.bottom: True

axes.grid: True
grid.color: "#c8c8c8"
grid.linestyle: -
grid.linewidth: 0.7
grid.alpha: 0.3

xtick.color: "#333333"
ytick.color: "#333333"
xtick.major.pad: 5
ytick.major.pad: 5
xtick.major.width: 0.6
ytick.major.width: 0.6
xtick.major.size: 2
ytick.major.size: 2
xtick.minor.size: 0
ytick.minor.size: 0
xtick.direction: out
ytick.direction: out

patch.edgecolor: white
patch.linewidth: 0.8
patch.facecolor: "#20BDB8"
